# JWT_SECRET: Clave secreta para firmar tokens de sesión. Generar con: openssl rand -hex 64
# REEMPLAZAR antes de producción
JWT_SECRET=""

# ALLOWED_EMAILS: Emails autorizados como fallback cuando Supabase no está configurado
ALLOWED_EMAILS=""

# APP_URL: URL donde está alojado este applet
APP_URL=""

# SUPERVISOR_PASSWORD: Contraseña para acceso supervisor (opcional, solo si no se usa Google Auth)
# Sin valor por defecto en producción. Configurar solo si es necesario.
SUPERVISOR_PASSWORD=""

# SUPABASE_URL: URL del proyecto Supabase del CRM
SUPABASE_URL=""
# SUPABASE_ANON_KEY: Anon key del proyecto Supabase del CRM
SUPABASE_ANON_KEY=""

# OPENROUTER_API_KEY: API key de OpenRouter para análisis cognitivo
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL: Modelo de OpenRouter a usar
OPENROUTER_MODEL="openrouter/free"
# ASSEMBLYAI_API_KEY: API key de AssemblyAI para transcripción
ASSEMBLYAI_API_KEY=""
