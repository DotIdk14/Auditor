{
  "version": 2,
  "framework": "vite",
  "installCommand": "cd ../.. && npm install --legacy-peer-deps --no-audit --no-fund",
  "buildCommand": "cd ../.. && npm run build -w apps/visor",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
