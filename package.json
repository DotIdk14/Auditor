{
  "name": "@auditor/monorepo",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n visor,srv -c cyan,yellow \"npm run dev -w apps/visor\" \"npm run dev -w apps/server\"",
    "dev:visor": "npm run dev -w apps/visor",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build -w apps/visor && npm run build -w apps/server",
    "build:visor": "npm run build -w apps/visor",
    "build:server": "npm run build -w apps/server",
    "lint": "npm run lint -w apps/visor && npm run lint -w apps/server",
    "typecheck": "npm run lint -w packages/shared-types",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "turbo": "^2.5.0",
    "typescript": "~5.8.2"
  }
}
