# JWT_SECRET: Clave secreta para firmar tokens de sesión. Generar con: openssl rand -hex 64
JWT_SECRET="your-jwt-secret-change-in-production"

# ALLOWED_EMAILS: Emails autorizados como fallback cuando Supabase no está configurado (separados por coma)
ALLOWED_EMAILS="admin@utel.edu.mx"

# APP_URL: URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUPERVISOR_PASSWORD: Contraseña para acceso supervisor. Sin default en producción.
SUPERVISOR_PASSWORD="supervisoresutel"

# SUPABASE_URL: URL del proyecto Supabase del CRM (para validar roles)
SUPABASE_URL="https://fhorasaovdibuglfnkut.supabase.co"
# SUPABASE_ANON_KEY: Anon key del proyecto Supabase del CRM
SUPABASE_ANON_KEY="your-supabase-anon-key"

# OLLAMA_URL: URL del servidor Ollama local
OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL: Modelo de Ollama a usar
OLLAMA_MODEL="hermes3"
# ASSEMBLYAI_API_KEY: API key de AssemblyAI para transcripción
ASSEMBLYAI_API_KEY="tu-api-key-aqui"

