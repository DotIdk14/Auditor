# APP_URL: URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUPERVISOR_PASSWORD: Contraseña para acceso supervisor. Default: supervisoresutel
SUPERVISOR_PASSWORD="supervisoresutel"

# SUPABASE_URL: URL del proyecto Supabase del CRM (para validar roles)
SUPABASE_URL="https://fhorasaovdibuglfnkut.supabase.co"
# SUPABASE_ANON_KEY: Anon key del proyecto Supabase del CRM
SUPABASE_ANON_KEY="your-supabase-anon-key"

# OLLAMA_URL: URL del servidor Ollama local
OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL: Modelo de Ollama a usar
OLLAMA_MODEL="hermes3"
# WHISPER_MODEL_PATH: Ruta al modelo GGML de Whisper
WHISPER_MODEL_PATH="./node_modules/@napi-rs/whisper/scripts/ggml-small.bin"

