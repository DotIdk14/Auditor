{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/ollama",
      "destination": "/api/ollama.ts"
    },
    {
      "source": "/api/whisper",
      "destination": "/api/whisper.ts"
    },
    {
      "source": "/api/upload-url",
      "destination": "/api/upload-url.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}